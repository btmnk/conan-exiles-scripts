{
  "name": "conan-exiles-cli",
  "version": "1.0.0",
  "description": "Conan Exiles dedicated server management CLI",
  "bin": {
    "conan": "src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build --compile src/index.ts --outfile bin/conan",
    "build:script": "bun build --target=bun src/index.ts --outfile bin/conan.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "26.0.1"
  }
}
